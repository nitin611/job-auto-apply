# Auto Job Apply — environment config
# Copy to .env and fill in. Never commit .env.

# LLM transport: claude_cli (default) or agent_sdk
CLAUDE_TRANSPORT=claude_cli
CLAUDE_BIN=claude

# LLM provider: claude_cli (default) or gemini_cli
# Can also be changed at runtime via Profile > LLM Provider in the UI
LLM_PROVIDER=claude_cli
GEMINI_BIN=gemini

# Safety: when true, apply handlers log what they WOULD submit but don't actually submit.
# Strongly recommended for first runs. Flip to false once you trust scoring.
DRY_RUN=true

# DB
DB_PATH=./data/jobs.db
LOG_LEVEL=INFO

# Gmail digest (optional — leave blank to disable email)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Server
HOST=127.0.0.1
PORT=8000
